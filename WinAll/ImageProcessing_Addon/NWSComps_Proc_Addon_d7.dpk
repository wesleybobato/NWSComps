package NWSComps_Proc_Addon_D7;

{$R *.res}
{$ALIGN 8}
{$ASSERTIONS ON}
{$BOOLEVAL OFF}
{$DEBUGINFO ON}
{$EXTENDEDSYNTAX ON}
{$IMPORTEDDATA ON}
{$IOCHECKS ON}
{$LOCALSYMBOLS ON}
{$LONGSTRINGS ON}
{$OPENSTRINGS ON}
{$OPTIMIZATION OFF}
{$OVERFLOWCHECKS OFF}
{$RANGECHECKS OFF}
{$REFERENCEINFO ON}
{$SAFEDIVIDE OFF}
{$STACKFRAMES ON}
{$TYPEDADDRESS OFF}
{$VARSTRINGCHECKS ON}
{$WRITEABLECONST OFF}
{$MINENUMSIZE 1}
{$IMAGEBASE $400000}
{$DESCRIPTION 'NWSComps_Proc_Addon'}
{$IMPLICITBUILD ON}
{$DEFINE DEBUG}

requires
  rtl,
  NWSComps_RGBCurves_D7,
  NWSComps_Shared_D7;

contains
  NWSComps_Proc in 'NWSComps_Proc.pas',
  NWSComps_Proc_Filter_Lib in 'NWSComps_Proc_Filter_Lib.pas',
  NWSComps_Proc_Filter_Lib_Const in 'NWSComps_Proc_Filter_Lib_Const.pas',
  NWSComps_Proc_Filter_Types in 'NWSComps_Proc_Filter_Types.pas',
  NWSComps_Proc_Reg in 'NWSComps_Proc_Reg.pas',
  NWSComps_Proc_Engine in 'NWSComps_Proc_Engine.pas',
  NWSComps_MultiThreadProc in 'NWSComps_MultiThreadProc.pas',
  NWSComps_FiltersPanel in 'NWSComps_FiltersPanel.pas';


end.

