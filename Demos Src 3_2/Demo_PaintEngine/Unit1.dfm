          Height = 257
          Lines.Strings = (
            
              'This mode lets you paint with any TIEBitmap on top of the curren' +
              't '
            'layer.'
            ' It is called HistoryMode because it can be used to restore an '
            'image contained '
            'in the imageenview undo list.'
            ''
            'Please check the implementation in this demo (procedure '
            'getHistoryBMP)'
            
              ' to understand how to load  an undo image into the HistoryBitmap' +
              ' '
            'property')
          TabOrder = 0
        end
